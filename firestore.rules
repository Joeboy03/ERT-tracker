rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['categories', 'dailyGoal', 'baseRate', 'premiumRate', 'showEarnings'])
        && (data.get('categories', []) is list)
        && (data.get('categories', []).size() <= 50)
        && (data.get('dailyGoal', 0) is number)
        && (data.get('baseRate', 0) is number)
        && (data.get('premiumRate', 0) is number)
        && (data.get('showEarnings', true) is bool);
    }

    function isValidDailyLog(data, userId) {
      return data.keys().hasOnly(['userId', 'dateKey', 'tasks'])
        && data.userId == userId
        && data.dateKey is string && data.dateKey.size() <= 64
        && data.tasks is list
        && data.tasks.size() <= 1000;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if isOwner(userId);

      match /logs/{dateKey} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(dateKey) && isValidDailyLog(incoming(), userId);
        allow update: if isOwner(userId) && isValidDailyLog(incoming(), userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
